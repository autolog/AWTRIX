<Template>
    <Field id="header-conn" type="label" alwaysUseInDialogHeightCalc="true" fontColor="green">
        <Label>MQTT BROKER CONNECTION</Label>
    </Field>

    <Field id="space-conn-1" type="label" alwaysUseInDialogHeightCalc="true"><Label/></Field>

    <Field id="mqttClientPrefix" type="textfield" defaultValue="indigo_awtrix" alwaysUseInDialogHeightCalc="true">
        <Label>MQTT Client Prefix:</Label>
    </Field>
    <Field id="help-prefix" type="label" alignWithControl="true" fontSize="small" fontColor="darkgray" alwaysUseInDialogHeightCalc="true">
        <Label>Unique prefix for MQTT client ID. The plugin appends the device ID.</Label>
    </Field>

    <Field id="space-conn-2" type="label" alwaysUseInDialogHeightCalc="true"><Label/></Field>

    <Field id="mqttProtocol" type="menu" defaultValue="4" alwaysUseInDialogHeightCalc="true">
        <Label>MQTT Protocol:</Label>
        <List>
            <Option value="4">MQTTv311</Option>
            <Option value="3">MQTTv31</Option>
        </List>
    </Field>

    <Field id="space-conn-3" type="label" alwaysUseInDialogHeightCalc="true"><Label/></Field>

    <Field id="mqtt_broker_ip" type="textfield" defaultValue="" alwaysUseInDialogHeightCalc="true">
        <Label>MQTT Broker IP:</Label>
    </Field>

    <Field id="mqtt_broker_port" type="textfield" defaultValue="1883" alwaysUseInDialogHeightCalc="true">
        <Label>MQTT Broker Port:</Label>
    </Field>

    <Field id="space-conn-4" type="label" alwaysUseInDialogHeightCalc="true"><Label/></Field>

    <Field id="mqtt_username" type="textfield" defaultValue="" alwaysUseInDialogHeightCalc="true">
        <Label>MQTT Username:</Label>
    </Field>

    <Field id="mqtt_password" type="textfield" secure="false" defaultValue="" alwaysUseInDialogHeightCalc="true">
        <Label>MQTT Password:</Label>
    </Field>
    <Field id="mqtt_password_encryption_key" type="textfield" hidden="true" defaultValue=""/>
    <Field id="mqtt_password_is_encoded" type="checkbox" hidden="true" defaultValue="false"/>

    <Field id="space-conn-5" type="label" alwaysUseInDialogHeightCalc="true"><Label/></Field>
</Template>
